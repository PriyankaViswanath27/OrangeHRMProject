<?xml version="1.0" encoding="UTF-8"?>
<configuration status="WARN">

<appenders>
      <!-- Console Appender -->
      <console name="Console" target="SYSTEM_OUT">
            <patternlayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %C{1} - %msg%n"/>
      </console>
      
      <!-- General File Appender-->
      <file name="FileLogger" filename="logs/app.log" append="true">
          <filters>
              <!-- Exclude ERROR and FATAL logs-->
              <threasholdfilter level="error" onMatch="DENY" onMismatch="ACCEPT"/>
              <patternlayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %C{1} - %msg%n"/>
          </filters>
     </file>
     
     <!-- Error File Appender-->
     <file name="ErrorFileLogger" filename="logs/error.log" append="true">
          <filters>
              <!-- Include only ERROR and FATAL logs-->
              <threasholdfilter level="error" onMatch="ACCEPT" onMismatch="DENY"/>
              <patternlayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %C{1} - %msg%n"/>
          </filters>
     </file>

</appenders>


 <loggers>
     <!-- Logger for com.orangehrm (specified package name here-->
     <logger name="com.orangehrm" level="trace" additivity="false">
         <appenderref ref="Console"/>
          <appenderref ref="FileLogger"/>
           <appenderref ref="ErrorFileLogger"/>
     </logger>
 
 </loggers>

</configuration>